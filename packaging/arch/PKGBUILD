pkgname=anycubic-cloud-manager-v3
pkgver=0.1.0
pkgrel=1
pkgdesc="Anycubic Cloud Manager V3 (Qt6/QML)"
arch=('x86_64')
url="https://github.com/MolgoVulgo/anycubic-cloud-manager-v3"
license=('MIT')
depends=(
  'qt6-base'
  'qt6-declarative'
  'qt6-5compat'
  'qt6-shadertools'
  'qt6-quick3d'
  'qt6-mqtt'
  'openssl'
)
makedepends=(
  'cmake'
  'ninja'
  'pkgconf'
  'gcc'
)
source=(
  "anycubic-cloud-manager-v3-main.zip::https://github.com/MolgoVulgo/anycubic-cloud-manager-v3/archive/refs/heads/main.zip"
)
sha256sums=(
  'SKIP'
)

build() {
  local _srcdir="${srcdir}/anycubic-cloud-manager-v3-main/accloud"
  cd "${_srcdir}"
  cmake --preset prod
  cmake --build --preset prod --target accloud_cli
}

package() {
  local _srcdir="${srcdir}/anycubic-cloud-manager-v3-main/accloud"
  cd "${_srcdir}"

  install -d "${pkgdir}/opt/accloud"
  install -m755 "build/prod/accloud_cli" "${pkgdir}/opt/accloud/accloud_cli"

  if [[ -d "resources" ]]; then
    cp -r "resources" "${pkgdir}/opt/accloud/resources"
  fi

  install -d "${pkgdir}/usr/share/applications"
  install -m644 "packaging/arch/accloud.desktop" "${pkgdir}/usr/share/applications/accloud.desktop"

  install -d "${pkgdir}/usr/share/metainfo"
  install -m644 "packaging/org.accloud.App.metainfo.xml" \
    "${pkgdir}/usr/share/metainfo/org.accloud.App.metainfo.xml"

  install -d "${pkgdir}/usr/share/licenses/${pkgname}"
  install -m644 "LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"

  install -d "${pkgdir}/var/log/accloud"
}
