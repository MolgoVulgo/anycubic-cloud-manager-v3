{
  "version": 5,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default (Ninja)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ACCLOUD_ENABLE_QT": "ON",
        "ACCLOUD_DEBUG": "OFF"
      }
    },
    {
      "name": "dev-debug",
      "displayName": "Dev Debug Tools (Ninja)",
      "inherits": "default",
      "binaryDir": "${sourceDir}/build/dev-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ACCLOUD_ENABLE_QT": "ON",
        "ACCLOUD_DEBUG": "ON"
      }
    },
    {
      "name": "prod",
      "displayName": "Production (Release)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/prod",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ACCLOUD_ENABLE_QT": "ON",
        "ACCLOUD_DEBUG": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default"
    },
    {
      "name": "dev-debug",
      "configurePreset": "dev-debug"
    },
    {
      "name": "prod",
      "configurePreset": "prod"
    }
  ],
  "testPresets": [
    {
      "name": "default",
      "configurePreset": "default"
    },
    {
      "name": "dev-debug",
      "configurePreset": "dev-debug"
    },
    {
      "name": "prod",
      "configurePreset": "prod"
    }
  ]
}
